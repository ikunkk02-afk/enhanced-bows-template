{
	"schemaVersion": 1,
	"id": "enhanced-bows",
	"version": "${version}",
	"name": "Enhanced Bows",
	"description": "A Fabric 1.21.1 bow enhancement mod featuring spectral-arrow scanning, Lightning storms, Burst explosions, Arrow Rain, configurable HUDs, and custom sound imports.",
	"authors": [
		"shouyun"
	],
	"contact": {
		"homepage": "https://space.bilibili.com/1832031043",
		"sources": "https://github.com/ikunkk02-afk/enhanced-bows-template",
		"douyin": "https://v.douyin.com/75aDMY8LVM8/",
		"bilibili": "https://space.bilibili.com/1832031043"
	},
	"license": "MIT",
	"icon": "assets/enhanced-bows/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"io.github.ikunkk02.enhancedbows.EnhancedBows"
		],
		"cardinal-components": [
			"io.github.ikunkk02.enhancedbows.lightning.LightningComponents",
			"io.github.ikunkk02.enhancedbows.arrowrain.ArrowRainComponents"
		],
		"client": [
			"io.github.ikunkk02.enhancedbows.client.EnhancedBowsClient"
		],
		"modmenu": [
			"io.github.ikunkk02.enhancedbows.client.config.EnhancedBowsModMenu"
		],
		"fabric-datagen": [
			"io.github.ikunkk02.enhancedbows.client.EnhancedBowsDataGenerator"
		]
	},
	"mixins": [
		"enhanced-bows.mixins.json",
		{
			"config": "enhanced-bows.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*",
		"cardinal-components-base": ">=6.1.3",
		"cardinal-components-entity": ">=6.1.3",
		"cloth-config": ">=15.0.140",
		"modmenu": ">=11.0.4"
	},
	"custom": {
		"cardinal-components": [
			"enhanced-bows:lightning_charge",
			"enhanced-bows:arrow_rain"
		]
	}
}
